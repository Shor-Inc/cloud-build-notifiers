[
  {
    "type": "section",
    "text": {
      "type": "mrkdwn",
      "text": ":cloud: *Cloud Build - {{.Build.Status}}*"
    }
  },
  {
    "type": "section",
    "fields": [
      {
        "type": "mrkdwn",
        "text": "*Trigger:*\n{{.Build.Substitutions.TRIGGER_NAME}}"
      },
      {
        "type": "mrkdwn",
        "text": "*Branch:*\n{{.Build.Substitutions.BRANCH_NAME}}"
      }
    ]
  },
  {
    "type": "section",
    "fields": [
      {
        "type": "mrkdwn",
        "text": "*Project:*\n{{.Build.ProjectId}}"
      },
      {
        "type": "mrkdwn",
        "text": "*Build ID:*\n{{.Build.Id}}"
      }
    ]
  },
  {
    "type": "actions",
    "elements": [
      {
        "type": "button",
        "text": {
          "type": "plain_text",
          "text": "View Logs",
          "emoji": true
        },
        "url": "{{.Build.LogUrl}}",
        "style": "primary"
      }
    ]
  }
]
